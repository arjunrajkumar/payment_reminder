<% @page_title = "Settings" %>
<% @body_class = "app-workspace" %>

<%= render "receivables/nav", active: :settings %>

<h1 class="app-page-title">Settings</h1>

<div class="app-section-grid">
  <section class="app-card">
    <h2 class="app-card__title">Business profile</h2>

    <div class="app-list">
      <div class="app-row">
        <div class="app-row__label">Company name</div>
        <div class="app-field"><%= @account.name %></div>
      </div>

      <div class="app-row">
        <div class="app-row__label">Billing email</div>
        <div class="app-field"><%= @billing_email || "Not set" %></div>
      </div>

      <div class="app-row">
        <div class="app-row__label">Currency</div>
        <div class="app-field"><%= @currency %></div>
      </div>
    </div>
  </section>

  <section class="app-card">
    <h2 class="app-card__title">Accounting integration</h2>

    <div class="app-list">
      <% @invoice_sources.each do |source| %>
        <% connected_source = source.connected_source %>
        <div class="app-row">
          <div class="app-row__text">
            <div class="app-row__label"><%= source.name %></div>
            <div class="app-row__note">
              <% if connected_source %>
                Synced <%= time_ago_in_words(connected_source.last_synced_at || connected_source.updated_at) %> ago
              <% else %>
                Not connected
              <% end %>
            </div>
          </div>

          <% if connected_source %>
            <span class="app-pill app-pill--green">Connected</span>
          <% else %>
            <%= link_to "Connect", public_send(source.connect_path_name), class: "app-pill app-pill--slate" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="app-card">
    <h2 class="app-card__title">Reminder cadence</h2>

    <div class="app-list">
      <div class="app-row">
        <div class="app-row__text">
          <div class="app-row__label">First reminder</div>
          <div class="app-row__note">Days after due date</div>
        </div>
        <div class="app-field">3 days</div>
      </div>

      <div class="app-row">
        <div class="app-row__text">
          <div class="app-row__label">Second reminder</div>
          <div class="app-row__note">Days after due date</div>
        </div>
        <div class="app-field">10 days</div>
      </div>

      <div class="app-row">
        <div class="app-row__text">
          <div class="app-row__label">Final notice</div>
          <div class="app-row__note">Days after due date</div>
        </div>
        <div class="app-field">21 days</div>
      </div>

      <div class="app-row">
        <div class="app-row__text">
          <div class="app-row__label">Auto-escalate exceptions</div>
          <div class="app-row__note">Hand off to a human on reply</div>
        </div>
        <span class="app-toggle app-toggle--on" aria-hidden="true"></span>
      </div>
    </div>
  </section>

  <section class="app-card">
    <h2 class="app-card__title">Notifications</h2>

    <div class="app-list">
      <div class="app-row">
        <div class="app-row__text">
          <div class="app-row__label">Weekly AR summary</div>
          <div class="app-row__note">Emailed every Monday</div>
        </div>
        <span class="app-toggle app-toggle--on" aria-hidden="true"></span>
      </div>

      <div class="app-row">
        <div class="app-row__label">Payment received alerts</div>
        <span class="app-toggle app-toggle--on" aria-hidden="true"></span>
      </div>

      <div class="app-row">
        <div class="app-row__label">Reminder reply alerts</div>
        <span class="app-toggle app-toggle--on" aria-hidden="true"></span>
      </div>

      <div class="app-row">
        <div class="app-row__label">Product updates</div>
        <span class="app-toggle" aria-hidden="true"></span>
      </div>
    </div>
  </section>
</div>
