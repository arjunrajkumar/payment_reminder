<% @page_title = "Settings" %>
<% @body_class = "app-workspace" %>

<%= render "layouts/shared/application_nav", active: :settings %>

<h1 class="app-page-title">Settings</h1>

<div class="app-section-grid">
  <section class="app-card">
    <h2 class="app-card__title">Business profile</h2>

    <div class="app-list">
      <div class="app-row">
        <div class="app-row__label">Company name</div>
        <div class="app-field"><%= @account.name %></div>
      </div>
    </div>
  </section>

  <section class="app-card">
    <h2 class="app-card__title">Accounting integration</h2>

    <div class="app-list">
      <% @invoice_sources.each do |source| %>
        <% connected_source = source.connected_source %>
        <div class="app-row">
          <div class="app-row__text">
            <div class="app-row__label"><%= source.name %></div>
            <div class="app-row__note">
              <% if connected_source %>
                Synced <%= time_ago_in_words(connected_source.last_synced_at || connected_source.updated_at) %> ago
              <% else %>
                Not connected
              <% end %>
            </div>
          </div>

          <% if connected_source %>
            <div class="app-row__actions">
              <span class="app-pill app-pill--green">Connected</span>
              <%= button_to invoice_source_refresh_path(connected_source), class: "app-inline-button", title: "Resync #{source.name} invoices" do %>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 11a8.1 8.1 0 0 0-15.5-2M4 4v5h5"></path>
                  <path d="M4 13a8.1 8.1 0 0 0 15.5 2M20 20v-5h-5"></path>
                </svg>
                <span>Resync</span>
              <% end %>
            </div>
          <% else %>
            <%= link_to "Connect", public_send(source.connect_path_name), class: "app-pill app-pill--slate" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="app-card">
    <h2 class="app-card__title">Invoice reminders</h2>

    <% if @outbound_email_connection %>
      <div class="app-list">
        <div class="app-row">
          <div class="app-row__text">
            <div class="app-row__label">Connected Gmail account</div>
            <div class="app-row__note"><%= @outbound_email_connection.connected_email %></div>
          </div>
          <span class="app-pill <%= @outbound_email_connection.active? ? "app-pill--green" : "app-pill--slate" %>">
            <%= @outbound_email_connection.status.humanize %>
          </span>
        </div>
      </div>

      <div class="app-settings-actions">
        <%= link_to "Reconnect Gmail",
          new_gmail_connection_path(script_name: @account.slug),
          class: "app-secondary-button" %>
        <% if @outbound_email_connection.active? %>
          <%= button_to "Send test email",
            test_gmail_connection_path(script_name: @account.slug),
            class: "app-secondary-button" %>
        <% end %>
        <%= button_to "Disconnect Gmail",
          gmail_connection_path(script_name: @account.slug),
          method: :delete,
          class: "app-secondary-button" %>
      </div>
    <% else %>
      <p class="app-card__description">
        Connect your company Gmail or Google Workspace account to send reminders from your real address.
        PaymentReminder uses Google access only as described in our
        <%= link_to "Privacy Policy", privacy_path(script_name: nil) %>.
      </p>
      <%= link_to "Connect Gmail",
        new_gmail_connection_path(script_name: @account.slug),
        class: "app-primary-button" %>
    <% end %>

    <%= form_with model: @account,
      url: account_settings_path(script_name: @account.slug),
      method: :patch,
      class: "app-reminder-settings-form" do |form| %>
      <% if @outbound_email_connection %>
        <div class="app-reminder-sender-field">
          <div class="app-row__text">
            <%= form.label :invoice_reminder_from_name,
              "Sender name",
              class: "app-row__label" %>
            <div class="app-row__note">Customers will see this name with your connected Gmail address.</div>
          </div>
          <%= form.text_field :invoice_reminder_from_name,
            maxlength: 100,
            placeholder: @account.name,
            class: "auth-input" %>
        </div>
      <% end %>

      <label class="app-reminder-setting">
        <span class="app-row__text">
          <span class="app-row__label">Automatic invoice reminders</span>
          <span class="app-row__note">Send reminders using each customer's current debtor rating.</span>
        </span>
        <%= form.check_box :automatic_invoice_reminders_enabled,
          disabled: !@account.outbound_email_ready?,
          class: "app-reminder-setting__checkbox" %>
      </label>

      <%= form.submit "Save reminder settings", class: "app-primary-button" %>
    <% end %>
  </section>

  <section class="app-card">
    <h2 class="app-card__title">Notifications</h2>

    <p class="app-card__description">Choose which invoice reminder events trigger an email to you.</p>

    <%= form_with url: account_notification_preferences_path(script_name: @account.slug),
      method: :patch,
      class: "app-reminder-settings-form" do %>
      <label class="app-reminder-setting">
        <span class="app-row__text">
          <span class="app-row__label">Invoice reminder sent</span>
          <span class="app-row__note">Email me after an automatic customer reminder succeeds.</span>
        </span>
        <%= check_box_tag "notifications[invoice_reminder]",
          "1",
          @notification_preferences["invoice_reminder"]&.email?,
          class: "app-reminder-setting__checkbox" %>
      </label>

      <label class="app-reminder-setting">
        <span class="app-row__text">
          <span class="app-row__label">Manual follow-up required</span>
          <span class="app-row__note">Email me after the last automatic reminder in a customer's sequence.</span>
        </span>
        <%= check_box_tag "notifications[invoice_reminder_stopped]",
          "1",
          @notification_preferences["invoice_reminder_stopped"]&.email?,
          class: "app-reminder-setting__checkbox" %>
      </label>

      <%= submit_tag "Save notification preferences", class: "app-primary-button" %>
    <% end %>
  </section>

</div>

<section class="app-table-card app-segment-rules-card">
  <div class="app-segment-rules-card__header">
    <div>
      <h2 class="app-card__title">Debtor ratings</h2>
      <p class="app-segment-rules-card__description">
        Ratings use up to the <%= CustomerSegment::PAYMENT_HISTORY_LIMIT %> most recent completed payment outcomes.
        Paid invoices count as on time when fully paid by the due date; uncollectible invoices count as not on time.
        Draft, open, and overdue invoices are excluded until resolved.
      </p>
      <p class="app-segment-rules-card__description">
        Customers with fewer than <%= CustomerSegment::MINIMUM_COMPLETED_OUTCOMES %> completed outcomes are always Normal Debtors.
        The outcome window and minimum history are fixed.
      </p>
    </div>

    <%= button_to "Refresh ratings",
      account_customer_segment_refresh_path(script_name: @account.slug),
      class: "app-secondary-button" %>
  </div>

  <%= form_with model: @account,
    url: account_settings_path(script_name: @account.slug),
    method: :patch,
    class: "app-segment-rules-form",
    data: { controller: "segment-rules" } do |form| %>
    <div class="app-table-wrap">
      <table class="app-data-table app-segment-rules-table">
        <thead>
          <tr>
            <th scope="col">Segment</th>
            <th scope="col">Current rule</th>
            <th scope="col">Adjust rule</th>
          </tr>
        </thead>
        <tbody>
          <% good_debtor_segment = @customer_segments.fetch("good_debtor") %>
          <tr>
            <td><strong>Good Debtor</strong></td>
            <td>
              At least <%= pluralize(CustomerSegment::MINIMUM_COMPLETED_OUTCOMES, "completed outcome") %>
              and <%= good_debtor_segment.on_time_rate %>% or more paid on time.
            </td>
            <td>
              <%= form.fields_for :customer_segments, good_debtor_segment, child_index: "good_debtor" do |segment_form| %>
                <div class="app-segment-rule-control">
                  <%= segment_form.label :on_time_rate, "On-time rate at least" %>
                  <%= segment_form.select :on_time_rate,
                    CustomerSegment::ON_TIME_RATE_OPTIONS.map { |rate| [ "#{rate}%", rate ] },
                    {},
                    class: "app-select",
                    data: {
                      segment_rules_target: "goodDebtorRate",
                      action: "segment-rules#updateOptionAvailability"
                    } %>
                  <small class="app-segment-rule-hint">Must stay above the Bad Debtor on-time rate.</small>
                </div>
              <% end %>
            </td>
          </tr>

          <tr>
            <td><strong>Normal Debtor</strong></td>
            <td>
              Fewer than <%= pluralize(CustomerSegment::MINIMUM_COMPLETED_OUTCOMES, "completed outcome") %>,
              or at least <%= @customer_segments.fetch("bad_debtor").on_time_rate %>% but under
              <%= good_debtor_segment.on_time_rate %>% paid on time.
            </td>
            <td><span class="app-segment-rule-automatic">Automatic range</span></td>
          </tr>

          <% bad_debtor_segment = @customer_segments.fetch("bad_debtor") %>
          <tr>
            <td><strong>Bad Debtor</strong></td>
            <td>
              At least <%= pluralize(CustomerSegment::MINIMUM_COMPLETED_OUTCOMES, "completed outcome") %>
              and under <%= bad_debtor_segment.on_time_rate %>% paid on time.
            </td>
            <td>
              <%= form.fields_for :customer_segments, bad_debtor_segment, child_index: "bad_debtor" do |segment_form| %>
                <div class="app-segment-rule-control">
                  <%= segment_form.label :on_time_rate, "On-time rate below" %>
                  <%= segment_form.select :on_time_rate,
                    CustomerSegment::ON_TIME_RATE_OPTIONS.map { |rate| [ "#{rate}%", rate ] },
                    {},
                    class: "app-select",
                    data: {
                      segment_rules_target: "badDebtorRate",
                      action: "segment-rules#updateOptionAvailability"
                    } %>
                  <small class="app-segment-rule-hint">Must stay below the Good Debtor on-time rate.</small>
                </div>
              <% end %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="app-segment-rules-form__actions">
      <%= form.submit "Save rules", class: "app-primary-button" %>
    </div>
  <% end %>
</section>

<div class="app-settings-actions">
  <%= button_to "Sign out", session_path(script_name: nil), method: :delete, class: "app-secondary-button" %>
</div>
