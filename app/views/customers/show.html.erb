<% @page_title = @customer.name %>
<% @body_class = "app-workspace" %>
<% payer_profile = customer_payer_profile(@customer) %>
<% invoice_status = customer_invoice_status(@customer) %>
<% timing_events = @customer.invoice_timing_events %>
<% outstanding_invoice_count = @customer.outstanding_invoices.size %>
<% open_invoice_count = @customer.open_invoices.size %>
<% uncollectible_invoice_count = @customer.uncollectible_invoices.size %>

<%= render "receivables/nav", active: :home %>

<nav class="app-breadcrumb app-customer-breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Receivables", home_path %>
  <span aria-hidden="true">/</span>
  <span aria-current="page"><%= @customer.name %></span>
</nav>

<header class="app-customer-header">
  <div>
    <h1 class="app-page-title"><%= @customer.name %></h1>
    <p class="app-page-subtitle">Customer segment: <%= payer_profile.fetch(:name) %></p>
  </div>

  <span class="app-invoice-status app-invoice-status--<%= invoice_status.fetch(:tone) %>"><%= invoice_status.fetch(:label) %></span>
</header>

<section class="app-card app-customer-summary" aria-labelledby="payment-summary-title">
  <h2 id="payment-summary-title" class="app-card__title">Payment summary</h2>

  <div class="app-customer-summary__receivable" aria-label="Receivable context">
    <% if outstanding_invoice_count.positive? %>
      <strong><%= receivable_totals(@customer.outstanding_totals, qualifier: "outstanding") %></strong>
      <span aria-hidden="true">·</span>
      <span><%= pluralize(outstanding_invoice_count, "invoice") %></span>
      <span aria-hidden="true">·</span>
      <span>
        <% if @customer.oldest_overdue_days %>
          <%= pluralize(@customer.oldest_overdue_days, "day") %> overdue
        <% else %>
          <%= customer_invoice_due_context(@customer.next_expected_invoice, as_of: @customer.as_of) %>
        <% end %>
      </span>
      <% if uncollectible_invoice_count.positive? %>
        <span aria-hidden="true">·</span>
        <span><%= pluralize(uncollectible_invoice_count, "uncollectible invoice") %></span>
      <% end %>
    <% elsif uncollectible_invoice_count.positive? %>
      <strong><%= receivable_totals(@customer.uncollectible_totals, qualifier: "uncollectible") %></strong>
      <span aria-hidden="true">·</span>
      <span><%= pluralize(uncollectible_invoice_count, "uncollectible invoice") %></span>
      <span aria-hidden="true">·</span>
      <span>No collection due</span>
      <% if open_invoice_count.positive? %>
        <span aria-hidden="true">·</span>
        <span><%= pluralize(open_invoice_count, "open invoice") %> with no balance due</span>
      <% end %>
    <% elsif open_invoice_count.positive? %>
      <strong>No balance due</strong>
      <span aria-hidden="true">·</span>
      <span><%= pluralize(open_invoice_count, "open invoice") %></span>
    <% else %>
      <strong>Paid in full</strong>
      <span aria-hidden="true">·</span>
      <span>No collection due</span>
    <% end %>
  </div>
</section>

<section class="app-card app-payment-history" aria-labelledby="payment-pattern-title">
  <header>
    <h2 id="payment-pattern-title" class="app-card__title">Invoice timing</h2>
  </header>

  <% if timing_events.any? %>
    <div class="app-payment-scale" aria-hidden="true">
      <span>30 days early</span>
      <span>Due date</span>
      <span>30 days late</span>
    </div>

    <div class="app-payment-events">
      <% timing_events.each do |event| %>
        <% invoice = event.fetch(:invoice) %>
        <div class="app-payment-event" data-testid="payment-history-event">
          <div class="app-payment-event__invoice">
            <strong><%= invoice.number.presence || invoice.external_id %></strong>
            <% if event.fetch(:uncollectible) %>
              <span>Uncollectible</span>
            <% elsif event.fetch(:no_balance_due) %>
              <span>Open · no balance due</span>
            <% elsif event.fetch(:paid) && invoice.paid_on.blank? %>
              <span>Paid</span>
            <% else %>
              <span><%= event.fetch(:paid) ? "Paid" : "Due" %> <%= customer_invoice_date(event.fetch(:paid) ? invoice.paid_on : invoice.due_on) %></span>
            <% end %>
          </div>
          <div class="app-payment-event__track" aria-hidden="true">
            <span class="app-payment-event__due-line"></span>
            <% if event.fetch(:position) %>
              <span class="app-payment-event__marker app-payment-event__marker--<%= customer_invoice_timing_tone(event) %>" style="--payment-position: <%= event.fetch(:position) %>%"></span>
            <% end %>
          </div>
          <div class="app-payment-event__timing">
            <strong><%= customer_invoice_timing_label(event) %></strong>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="app-empty-inline app-payment-history__empty">Invoice timing will appear when an invoice has a due date.</div>
  <% end %>
</section>
