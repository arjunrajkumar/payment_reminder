<% status = receivable_status(receivable, as_of: as_of) %>

<tr data-testid="customer-inbox-row">
  <td class="app-customer-card__identity" data-label="Customer">
    <div class="app-customer-card__identity-copy">
      <strong class="app-customer-card__name"><%= receivable.customer.name %></strong>
      <span class="app-customer-card__payer-segment"><%= receivable.payer_segment.humanize %></span>
    </div>
  </td>

  <td data-label="Receivables">
    <strong class="app-customer-card__amount">
      <% if receivable.outstanding_invoice_count.positive? %>
        <%= receivable_totals(receivable.outstanding_totals) %>
      <% elsif receivable.uncollectible_invoice_count.positive? %>
        <%= receivable_totals(receivable.uncollectible_totals, qualifier: "uncollectible") %>
      <% elsif receivable.open_invoice_count.positive? %>
        No balance due
      <% else %>
        Paid in full
      <% end %>
    </strong>
    <div class="app-table-note app-customer-card__receivable-context">
      <% if receivable.outstanding_invoice_count.positive? %>
        <%= receivable_due_context(receivable, as_of: as_of) %>
      <% else %>
        No collection due
      <% end %>
    </div>
    <% if receivable.outstanding_invoice_count > 1 %>
      <div class="app-table-note">for <%= pluralize(receivable.outstanding_invoice_count, "invoice") %></div>
    <% end %>
    <% if receivable.uncollectible_invoice_count.positive? %>
      <div class="app-table-note"><%= pluralize(receivable.uncollectible_invoice_count, "invoice") %> marked uncollectible</div>
    <% end %>
    <% if receivable.outstanding_invoice_count.zero? && receivable.uncollectible_invoice_count.positive? && receivable.open_invoice_count.positive? %>
      <div class="app-table-note"><%= pluralize(receivable.open_invoice_count, "open invoice") %> with no balance due</div>
    <% end %>
  </td>

  <td class="app-customer-card__status" data-label="Status">
    <span class="app-invoice-status app-invoice-status--<%= status.fetch(:tone) %>"><%= status.fetch(:label) %></span>
  </td>
</tr>
