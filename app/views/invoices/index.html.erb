<h1>Invoices</h1>

<p>Connected to <%= @invoice_sources.map { |source| source.external_account_name.presence || source.provider.titleize }.to_sentence %>.</p>

<% if @page.used? %>
  <table>
    <thead>
      <tr>
        <th>Number</th>
        <th>Customer</th>
        <th>Status</th>
        <th>Issued</th>
        <th>Due</th>
        <th>Total</th>
        <th>Due amount</th>
        <th>Platform</th>
      </tr>
    </thead>
    <tbody>
      <% @page.records.each do |invoice| %>
        <tr>
          <td><%= invoice.number.presence || invoice.external_id %></td>
          <td><%= invoice.contact_name %></td>
          <td><%= invoice.status %></td>
          <td><%= invoice.issued_on %></td>
          <td><%= invoice.due_on %></td>
          <td><%= number_to_currency invoice.total, unit: "#{invoice.currency} " %></td>
          <td><%= number_to_currency invoice.amount_due, unit: "#{invoice.currency} " %></td>
          <td><%= invoice.invoice_source.provider.titleize %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @page.before_last? %>
    <p><%= link_to "Load more", invoices_path(page: @page.next_param) %></p>
  <% end %>
<% else %>
  <p>No invoices synced yet.</p>
<% end %>
