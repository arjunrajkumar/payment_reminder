<!DOCTYPE html>
<html lang="en">
  <%= render "layouts/shared/head" %>

  <body class="<%= [ "public", body_classes ].reject(&:blank?).join(" ") %>" data-controller="timezone-cookie">
    <div id="global-container">
      <%= render "layouts/shared/flash" %>

      <main id="main" class="public-main">
        <%= yield %>
      </main>

      <footer class="public-footer">
        <%= link_to "Privacy Policy", privacy_path(script_name: nil) %>
        <span aria-hidden="true">·</span>
        <%= link_to "Terms of Service", terms_path(script_name: nil) %>
      </footer>
    </div>
  </body>
</html>
