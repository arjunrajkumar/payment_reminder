<% content_for :nav do %>
  <div class="app-mobile-nav-bar">
    <div class="app-logo app-logo--mobile" aria-hidden="true">
      <%= render "layouts/shared/logo_mark", suffix: "mobile" %>
    </div>

    <div class="app-mobile-nav-actions">
      <%= link_to account_settings_path, class: "app-icon-button", aria: { label: "Settings" } do %>
        <svg class="app-nav-item__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      <% end %>

      <button
        class="app-icon-button"
        type="button"
        aria-label="Toggle navigation"
        aria-controls="application-navigation-links"
        aria-expanded="false"
        data-toggle-class-target="trigger"
        data-action="toggle-class#toggle"
      >
        <svg class="app-nav-item__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 6h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div class="app-logo app-logo--desktop" aria-hidden="true">
    <%= render "layouts/shared/logo_mark", suffix: "desktop" %>
  </div>

  <div id="application-navigation-links" class="app-nav-list" data-toggle-class-target="panel">
    <%= link_to home_path, class: [ "app-nav-item", ("app-nav-item--active" if active == :home) ], aria: { current: ("page" if active == :home) } do %>
      <svg class="app-nav-item__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 4h16v16H4z"></path>
        <path d="M4 13h4l2 3h4l2-3h4"></path>
      </svg>
      Receivables
    <% end %>

    <%= link_to account_settings_path, class: [ "app-nav-item", ("app-nav-item--active" if active == :settings) ], aria: { current: ("page" if active == :settings) } do %>
      <svg class="app-nav-item__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
      Settings
    <% end %>
  </div>
<% end %>
