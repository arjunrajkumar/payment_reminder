<h1>Check your email</h1>

<p>Then enter the verification code included in the email below:</p>

<%= form_with url: session_magic_link_path, method: :post do |form| %>
  <p>
    <%= form.text_field :code, required: true, autofocus: true, autocorrect: "off", autocapitalize: "off", spellcheck: "false", autocomplete: "one-time-code", maxlength: "6", placeholder: "------", value: params[:code] %>
  </p>
<% end %>

<p>The code sent to <strong><%= email_address_pending_authentication %></strong> will work for <%= distance_of_time_in_words(MagicLink::EXPIRATION_TIME) %>.</p>

<% if Rails.env.development? && flash[:magic_link_code].present? %>
  <p>
    <span>Psst, here's your code:</span>
    <code><%= flash[:magic_link_code] %></code>
  </p>
<% end %>
