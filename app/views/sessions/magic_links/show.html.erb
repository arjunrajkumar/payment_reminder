<% @page_title = "Check your email" %>

<div class="auth-shell">
  <div class="auth-panel">
    <div class="auth-logo" aria-hidden="true">
      <%= render "layouts/shared/logo_mark", suffix: "magic-link", width: 48, height: 56 %>
    </div>

    <div class="auth-card">
      <h1 class="auth-title">Check your email</h1>
      <p class="auth-subtitle">Enter the verification code we sent you.</p>

      <%= form_with url: session_magic_link_path, method: :post, class: "auth-form", data: { turbo: false } do |form| %>
        <%= form.text_field :code, required: true, autofocus: true, autocorrect: "off", autocapitalize: "off", spellcheck: "false", autocomplete: "one-time-code", maxlength: "6", placeholder: "------", value: params[:code], class: "auth-input auth-input--code" %>

        <button type="submit" class="auth-button">
          <span>Continue</span>
          <svg class="auth-button__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </button>
      <% end %>

      <p class="auth-note">
        The code sent to <strong><%= email_address_pending_authentication %></strong> will work for <%= distance_of_time_in_words(MagicLink::EXPIRATION_TIME) %>.
      </p>

      <% if Rails.env.development? && flash[:magic_link_code].present? %>
        <div class="auth-dev-code">
          <span>Psst, here's your code:</span>
          <code><%= flash[:magic_link_code] %></code>
        </div>
      <% end %>
    </div>
  </div>
</div>
