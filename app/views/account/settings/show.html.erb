<% @page_title = "Settings" %>
<% @body_class = "app-workspace" %>

<%= render "layouts/shared/application_nav", active: :settings %>

<h1 class="app-page-title">Settings</h1>

<div class="app-section-grid">
  <section class="app-card">
    <h2 class="app-card__title">Business profile</h2>

    <div class="app-list">
      <div class="app-row">
        <div class="app-row__label">Company name</div>
        <div class="app-field"><%= @account.name %></div>
      </div>
    </div>
  </section>

  <section class="app-card">
    <h2 class="app-card__title">Accounting integration</h2>

    <div class="app-list">
      <% @invoice_sources.each do |source| %>
        <% connected_source = source.connected_source %>
        <div class="app-row">
          <div class="app-row__text">
            <div class="app-row__label"><%= source.name %></div>
            <div class="app-row__note">
              <% if connected_source %>
                Synced <%= time_ago_in_words(connected_source.last_synced_at || connected_source.updated_at) %> ago
              <% else %>
                Not connected
              <% end %>
            </div>
          </div>

          <% if connected_source %>
            <div class="app-row__actions">
              <span class="app-pill app-pill--green">Connected</span>
              <%= button_to invoice_source_refresh_path(connected_source), class: "app-inline-button", title: "Resync #{source.name} invoices" do %>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 11a8.1 8.1 0 0 0-15.5-2M4 4v5h5"></path>
                  <path d="M4 13a8.1 8.1 0 0 0 15.5 2M20 20v-5h-5"></path>
                </svg>
                <span>Resync</span>
              <% end %>
            </div>
          <% else %>
            <%= link_to "Connect", public_send(source.connect_path_name), class: "app-pill app-pill--slate" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

</div>

<section class="app-table-card app-segment-rules-card">
  <div class="app-segment-rules-card__header">
    <div>
      <h2 class="app-card__title">Customer segments</h2>
      <p class="app-segment-rules-card__description">Choose how Payment Reminder labels customers from their recent payment history.</p>
    </div>

    <%= button_to "Refresh segments",
      account_customer_segment_refresh_path(script_name: @account.slug),
      class: "app-secondary-button" %>
  </div>

  <%= form_with model: @account,
    url: account_settings_path(script_name: @account.slug),
    method: :patch,
    class: "app-segment-rules-form",
    data: { controller: "segment-rules" } do |form| %>
    <div class="app-table-wrap">
      <table class="app-data-table app-segment-rules-table">
        <thead>
          <tr>
            <th scope="col">Segment</th>
            <th scope="col">Current rule</th>
            <th scope="col">Adjust rule</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>New</strong></td>
            <td>Fewer than <%= pluralize(@account.payer_segment_minimum_payment_history, "eligible payment") %>.</td>
            <td>
              <div class="app-segment-rule-control">
                <%= form.label :payer_segment_minimum_payment_history, "Minimum history" %>
                <%= form.select :payer_segment_minimum_payment_history,
                  Account::PayerSegment::HISTORY_OPTIONS.map { |count| [ pluralize(count, "payment"), count ] },
                  {},
                  class: "app-select",
                  data: {
                    segment_rules_target: "minimumHistory",
                    action: "segment-rules#updateOptionAvailability"
                  } %>
                <small class="app-segment-rule-hint">Cannot exceed the unreliable payer minimum history</small>
              </div>
            </td>
          </tr>
          <tr>
            <td><strong>Pays on time</strong></td>
            <td>At least <%= @account.payer_segment_pays_on_time_rate %>% paid by the due date.</td>
            <td>
              <div class="app-segment-rule-control">
                <%= form.label :payer_segment_pays_on_time_rate, "On-time rate" %>
                <%= form.select :payer_segment_pays_on_time_rate,
                  Account::PayerSegment::PAYS_ON_TIME_RATE_OPTIONS.map { |rate| [ "#{rate}% or more", rate ] },
                  {},
                  class: "app-select",
                  data: {
                    segment_rules_target: "paysOnTimeRate",
                    action: "segment-rules#updateOptionAvailability"
                  } %>
                <small class="app-segment-rule-hint">Must stay above the unreliable payer on-time rate.</small>
              </div>
            </td>
          </tr>
          <tr>
            <td><strong>Slow payer</strong></td>
            <td>Typical payment is more than <%= pluralize(@account.payer_segment_slow_payer_days, "day") %> late.</td>
            <td>
              <div class="app-segment-rule-control">
                <%= form.label :payer_segment_slow_payer_days, "Typical delay" %>
                <%= form.select :payer_segment_slow_payer_days,
                  Account::PayerSegment::SLOW_PAYER_DAYS_OPTIONS.map { |days| [ pluralize(days, "day"), days ] },
                  {},
                  class: "app-select" %>
              </div>
            </td>
          </tr>
          <tr>
            <td><strong>Unreliable payer</strong></td>
            <td>
              Any recent uncollectible invoice, or at least <%= pluralize(@account.payer_segment_minimum_unreliable_history, "eligible payment") %>
              with under <%= @account.payer_segment_unreliable_on_time_rate %>% paid on time, a typical delay over
              <%= pluralize(@account.payer_segment_slow_payer_days, "day") %>, and inconsistent timing.
            </td>
            <td>
              <div class="app-segment-rule-controls">
                <div class="app-segment-rule-control">
                  <%= form.label :payer_segment_minimum_unreliable_history, "Minimum history" %>
                  <%= form.select :payer_segment_minimum_unreliable_history,
                    Account::PayerSegment::HISTORY_OPTIONS.map { |count| [ pluralize(count, "payment"), count ] },
                    {},
                    class: "app-select",
                    data: {
                      segment_rules_target: "unreliableHistory",
                      action: "segment-rules#updateOptionAvailability"
                    } %>
                  <small class="app-segment-rule-hint">Must be at least the New minimum history</small>
                </div>
                <div class="app-segment-rule-control">
                  <%= form.label :payer_segment_unreliable_on_time_rate, "On-time rate below" %>
                  <%= form.select :payer_segment_unreliable_on_time_rate,
                    Account::PayerSegment::UNRELIABLE_ON_TIME_RATE_OPTIONS.map { |rate| [ "#{rate}%", rate ] },
                    {},
                    class: "app-select",
                    data: {
                      segment_rules_target: "unreliableOnTimeRate",
                      action: "segment-rules#updateOptionAvailability"
                    } %>
                  <small class="app-segment-rule-hint">Must stay below the pays-on-time rate.</small>
                </div>
              </div>
            </td>
          </tr>
          <tr>
            <td><strong>Sometimes late</strong></td>
            <td>Payment timing does not match another segment.</td>
            <td><span class="app-segment-rule-automatic">Automatic fallback</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="app-segment-rules-form__actions">
      <%= form.submit "Save rules", class: "app-primary-button" %>
    </div>
  <% end %>
</section>

<div class="app-settings-actions">
  <%= button_to "Sign out", session_path(script_name: nil), method: :delete, class: "app-secondary-button" %>
</div>
