<h1>Complete your sign-up</h1>

<%= form_with model: @signup, url: signup_completion_path, scope: "signup" do |form| %>
  <p>
    <%= form.text_field :full_name, autocomplete: "name", placeholder: "Enter your full name...", autofocus: true, required: true, maxlength: 240 %>
  </p>

  <p>You're one step away. Just enter your name to get your own PaidJar account.</p>

  <% if @signup.errors.any? %>
    <div>
      <p>Your changes couldn't be saved:</p>
      <ul>
        <% @signup.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <button type="submit">
    <span>Continue</span>
    <span>-></span>
  </button>
<% end %>
