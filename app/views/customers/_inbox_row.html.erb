<% invoice_status = customer_invoice_status(customer) %>
<% payer_profile = customer_payer_profile(customer) %>
<% outstanding_invoice_count = customer.outstanding_invoices.size %>
<% open_invoice_count = customer.open_invoices.size %>
<% uncollectible_invoice_count = customer.uncollectible_invoices.size %>

<tr data-testid="customer-inbox-row">
  <td class="app-customer-card__identity" data-label="Customer">
    <div class="app-customer-card__identity-copy">
      <%= link_to customer.name, customer_path(customer), class: "app-data-link" %>
      <span class="app-customer-card__payer-profile"><%= payer_profile.fetch(:name) %></span>
    </div>
  </td>

  <td data-label="Receivable">
    <strong class="app-customer-card__amount">
      <% if outstanding_invoice_count.positive? %>
        <%= receivable_totals(customer.outstanding_totals) %>
      <% elsif uncollectible_invoice_count.positive? %>
        <%= receivable_totals(customer.uncollectible_totals, qualifier: "uncollectible") %>
      <% elsif open_invoice_count.positive? %>
        No balance due
      <% else %>
        Paid in full
      <% end %>
    </strong>
    <div class="app-table-note app-customer-card__receivable-context">
      <% if customer.oldest_overdue_days %>
        <%= pluralize(customer.oldest_overdue_days, "day") %> overdue
      <% elsif outstanding_invoice_count.positive? %>
        <%= customer_invoice_due_context(customer.next_expected_invoice, as_of: customer.as_of) %>
      <% else %>
        No collection due
      <% end %>
    </div>
    <% if outstanding_invoice_count > 1 %>
      <div class="app-table-note">for <%= pluralize(outstanding_invoice_count, "invoice") %></div>
    <% end %>
    <% if uncollectible_invoice_count.positive? %>
      <div class="app-table-note"><%= pluralize(uncollectible_invoice_count, "invoice") %> marked uncollectible</div>
    <% end %>
    <% if outstanding_invoice_count.zero? && uncollectible_invoice_count.positive? && open_invoice_count.positive? %>
      <div class="app-table-note"><%= pluralize(open_invoice_count, "open invoice") %> with no balance due</div>
    <% end %>
  </td>

  <td class="app-customer-card__status" data-label="Status">
    <span class="app-invoice-status app-invoice-status--<%= invoice_status.fetch(:tone) %>"><%= invoice_status.fetch(:label) %></span>
  </td>
</tr>
