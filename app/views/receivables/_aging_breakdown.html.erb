<% aging_series = dashboard.aging_series %>
<% older_than_thirty_totals = dashboard.older_than_thirty_totals %>

<section class="app-card app-aging-card" aria-labelledby="aging-breakdown-title">
  <header>
    <h2 id="aging-breakdown-title" class="app-card__title">Breakdown of outstanding receivables</h2>
  </header>

  <% if aging_series.any? %>
    <% aging_series.each do |series| %>
      <% currency = series.fetch(:currency) %>

      <div class="app-aging-chart" role="group" aria-label="Aging breakdown in <%= currency %>">
        <% if aging_series.many? %>
          <div class="app-aging-chart__currency"><%= currency %></div>
        <% end %>

        <div class="app-aging-chart__plot">
          <% series.fetch(:buckets).each do |bucket| %>
            <div
              class="app-aging-chart__item"
              data-testid="aging-<%= bucket.fetch(:test_id) %>"
            >
              <div class="app-aging-chart__label">
                <%= bucket.fetch(:label) %>
                <strong><%= number_to_percentage(bucket.fetch(:percentage), precision: 0) %></strong>
              </div>
              <div class="app-aging-chart__track" aria-hidden="true">
                <div
                  class="app-aging-chart__bar app-aging-chart__bar--<%= bucket.fetch(:test_id) %>"
                  style="--aging-bar-size: <%= bucket.fetch(:percentage) %>%"
                ></div>
              </div>
              <div class="app-aging-chart__value"><%= receivable_amount(bucket.fetch(:amount), currency) %></div>
            </div>
          <% end %>
        </div>

        <p class="app-aging-chart__insight">
          <%= receivable_amount(older_than_thirty_totals.fetch(currency, 0), currency) %> is more than 30 days overdue.
        </p>
      </div>
    <% end %>
  <% else %>
    <p class="app-aging-card__empty">No outstanding balances to age.</p>
  <% end %>
</section>
