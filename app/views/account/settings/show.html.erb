<% @page_title = "Settings" %>
<% @body_class = "app-workspace" %>

<%= render "receivables/nav", active: :settings %>

<h1 class="app-page-title">Settings</h1>

<div class="app-section-grid">
  <section class="app-card">
    <h2 class="app-card__title">Business profile</h2>

    <div class="app-list">
      <div class="app-row">
        <div class="app-row__label">Company name</div>
        <div class="app-field"><%= @account.name %></div>
      </div>
    </div>
  </section>

  <section class="app-card">
    <h2 class="app-card__title">Accounting integration</h2>

    <div class="app-list">
      <% @invoice_sources.each do |source| %>
        <% connected_source = source.connected_source %>
        <div class="app-row">
          <div class="app-row__text">
            <div class="app-row__label"><%= source.name %></div>
            <div class="app-row__note">
              <% if connected_source %>
                Synced <%= time_ago_in_words(connected_source.last_synced_at || connected_source.updated_at) %> ago
              <% else %>
                Not connected
              <% end %>
            </div>
          </div>

          <% if connected_source %>
            <div class="app-row__actions">
              <span class="app-pill app-pill--green">Connected</span>
              <%= button_to invoice_source_refresh_path(connected_source), class: "app-inline-button", title: "Resync #{source.name} invoices" do %>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 11a8.1 8.1 0 0 0-15.5-2M4 4v5h5"></path>
                  <path d="M4 13a8.1 8.1 0 0 0 15.5 2M20 20v-5h-5"></path>
                </svg>
                <span>Resync</span>
              <% end %>
            </div>
          <% else %>
            <%= link_to "Connect", public_send(source.connect_path_name), class: "app-pill app-pill--slate" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

</div>

<div class="app-settings-actions">
  <%= button_to "Sign out", session_path(script_name: nil), method: :delete, class: "app-secondary-button" %>
</div>
