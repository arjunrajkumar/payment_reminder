<% conversation = entry.conversation %>
<% message = entry.latest_message %>

<article class="app-card app-conversation-row">
  <%= link_to conversation_path(conversation), class: "app-conversation-row__link" do %>
    <div class="app-conversation-row__identity">
      <strong><%= conversation_name(
        conversation,
        latest_inbound_sender: entry.latest_inbound_sender
      ) %></strong>
      <span><%= conversation_invoice_reference(conversation) %></span>
    </div>

    <div class="app-conversation-row__summary">
      <strong><%= message&.subject.presence || "Collection work item" %></strong>
      <span><%= truncate(
        message&.body.to_s.squish.presence || entry.workflow_summary.to_s,
        length: 120
      ) %></span>
    </div>

    <div class="app-conversation-row__meta">
      <time datetime="<%= entry.latest_activity_at.iso8601 %>">
        <%= l(entry.latest_activity_at, format: :short) %>
      </time>
      <% if conversation.attention_required_at? %>
        <span class="app-inbox-chip app-inbox-chip--attention">Needs attention</span>
      <% end %>
      <% if entry.needs_review %>
        <span class="app-inbox-chip">Needs review</span>
      <% end %>
      <% if entry.collection_held %>
        <span class="app-inbox-chip app-inbox-chip--paused">Collection paused</span>
      <% end %>
    </div>
  <% end %>
</article>
